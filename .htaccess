Options -Indexes
RewriteEngine On

# Serve compressed JavaScript artifacts (*.js.gz) with strict JS MIME + gzip.
<IfModule mod_mime.c>
	AddEncoding gzip .gz
</IfModule>

<IfModule mod_headers.c>
	<FilesMatch "\.js\.gz$">
		Header set Content-Type "application/javascript; charset=UTF-8"
		Header set Content-Encoding "gzip"
		Header set X-Content-Type-Options "nosniff"
		Header append Vary "Accept-Encoding"
	</FilesMatch>
</IfModule>

<IfModule mod_mime.c>
	<FilesMatch "\.js\.gz$">
		ForceType application/javascript
	</FilesMatch>
</IfModule>

# Deny direct access to config files
RewriteRule ^config/ - [F,L]

# Canonical API prefix: /api/v1/*.php -> /api/*.php
RewriteRule ^api/v1/(.*)$ /api/$1 [QSA,L]

# PHP files in api/ are served normally
# Everything else (non-existing files/dirs) falls back to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/api/
RewriteRule ^(.*)$ /index.html [L]
